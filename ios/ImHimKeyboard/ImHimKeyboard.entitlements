<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
		App Group shared with the main Runner target. Lets the main app
		write configuration (selected vibe, last screenshot timestamp,
		analytics opt-in flag) to UserDefaults(suiteName:) and the
		keyboard extension read it. Also covers any future scenarios
		where we want to surface the last reply set back in the app.

		The same group ID must be enabled in Runner.entitlements AND
		registered on the Apple Developer portal under "App Groups".
	-->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.mirrorly.app.shared</string>
	</array>
</dict>
</plist>
