<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>ImHim</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>

	<!--
		CFBundleIcons + CFBundleIcons~ipad — tell App Store Connect's
		validator that our icon set is named "iMessage App Icon" and
		list the exact filenames at the bundle root. v209 added the
		individual PNG files to Resources but the validator only
		recognises them as iMessage icons when this dictionary points
		at them by basename. Without this the 134x100 lookup fails
		even though the file is there.
	-->
	<key>CFBundleIcons</key>
	<dict>
		<key>CFBundlePrimaryIcon</key>
		<dict>
			<key>CFBundleIconFiles</key>
			<array>
				<string>iMessage App Icon-29@2x</string>
				<string>iMessage App Icon-29@3x</string>
				<string>iMessage App Icon-60x45@2x</string>
				<string>iMessage App Icon-60x45@3x</string>
				<string>iMessage App Icon-67x50@2x</string>
				<string>iMessage App Icon-27x20@2x</string>
				<string>iMessage App Icon-27x20@3x</string>
				<string>iMessage App Icon-32x24@2x</string>
				<string>iMessage App Icon-32x24@3x</string>
			</array>
			<key>CFBundleIconName</key>
			<string>iMessage App Icon</string>
		</dict>
	</dict>
	<key>CFBundleIcons~ipad</key>
	<dict>
		<key>CFBundlePrimaryIcon</key>
		<dict>
			<key>CFBundleIconFiles</key>
			<array>
				<string>iMessage App Icon-29@2x-1</string>
				<string>iMessage App Icon-74x55@2x</string>
				<string>iMessage App Icon-27x20@2x</string>
				<string>iMessage App Icon-27x20@3x</string>
				<string>iMessage App Icon-32x24@2x</string>
				<string>iMessage App Icon-32x24@3x</string>
			</array>
			<key>CFBundleIconName</key>
			<string>iMessage App Icon</string>
		</dict>
	</dict>

	<!--
		iMessage App Extension. iOS 17's revamped Messages App Menu (the
		+ button next to the text field) automatically lists every app
		that declares this NSExtensionPointIdentifier, so we don't need
		anything special beyond the standard registration.
	-->
	<key>NSExtension</key>
	<dict>
		<key>NSExtensionPointIdentifier</key>
		<string>com.apple.message-payload-provider</string>
		<key>NSExtensionPrincipalClass</key>
		<string>$(PRODUCT_MODULE_NAME).MessagesViewController</string>
	</dict>

	<key>NSPhotoLibraryUsageDescription</key>
	<string>ImHim reads the screenshot you just took (or one you pick) so it can write three reply options to drop straight into your chat. The screenshot is sent once and not stored.</string>
</dict>
</plist>
