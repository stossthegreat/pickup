<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Share Extension joins the same App Group as the main Runner
	     so the file it writes is readable by the Flutter side. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.mirrorly.app.shared</string>
	</array>
</dict>
</plist>
