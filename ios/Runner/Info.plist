<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>NSCameraUsageDescription</key>
	<string>ImHim uses the camera only if you choose to take a photo to use inside the app. You are asked in-app before it is used. Manage in Settings.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>ImHim uses your microphone during live voice roleplay so you can practise conversations out loud and hear a spoken reply in real time. Your audio is sent securely to OpenAI to generate the reply, then discarded. Manage in Settings.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>ImHim reads a conversation screenshot you choose so it can extract the messages on your device and suggest three replies. The screenshot never leaves your device — only the extracted text is sent to generate suggestions. Manage in Settings.</string>
	<key>CFBundleDisplayName</key>
	<string>ImHim-Rizz</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>ImHim</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<!--
		URL Types — registers the "imhim://" custom scheme. The
		ImHimShare Share Extension deep-links into this scheme after
		writing the screenshot to the App Group, which surfaces the
		main Runner app + sends Flutter the "new shared screenshot
		landed" signal via ShareIntakeService.
	-->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.imhim.app</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>imhim</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
