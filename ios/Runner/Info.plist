<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>NSCameraUsageDescription</key>
	<string>Mirrorly uses your camera to capture a selfie for analysis, and during Eyes training drills to measure eye contact, blink rate and head stillness in real time. Before any photo leaves the device for AI analysis you'll be asked permission in-app. Manage in Settings.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Mirrorly uses your microphone in the Eyes and Game tabs to record your voice during rhetoric drills, Lucien's roleplay scenes, and live free-flow conversations. Audio is sent securely to OpenAI for transcription and the in-character reply, then discarded. Manage in Settings.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Mirrorly saves your before/after transformations to your photo library so you can share them.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Mirrorly reads the screenshot you select so the RIZZ tab can extract the messages on-device and generate three reply options. The screenshot never leaves your device — only the extracted text is sent for generation.</string>
	<key>CFBundleDisplayName</key>
	<string>Mirrorly</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>mirrorly</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<!--
		URL Types — registers the "imhim://" custom scheme. The
		ImHimShare Share Extension deep-links into this scheme after
		writing the screenshot to the App Group, which surfaces the
		main Runner app + sends Flutter the "new shared screenshot
		landed" signal via ShareIntakeService.
	-->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.mirrorly.app</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>imhim</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
