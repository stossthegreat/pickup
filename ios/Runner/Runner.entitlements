<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Group — paired with ImHimKeyboard.entitlements so the main
	     app can hand the keyboard extension config (vibe, API host) via
	     a shared UserDefaults suite. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.mirrorly.app.shared</string>
	</array>
</dict>
</plist>
